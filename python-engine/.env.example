# ============================================
# EchoSpeak AI — Python Engine 环境变量
# ============================================

# ---- LLM 对话引擎（必填，否则走 fallback 硬编码回复）----
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-secret-key-here
LLM_MODEL=deepseek-v4-flash

# ---- gRPC Server ----
GRPC_LISTEN_ADDR=0.0.0.0:50051

# ---- FastAPI Dev Server ----
DEV_PORT=8000

# ---- Redis ----
REDIS_ADDR=localhost:6379

# ---- TTS 语音合成 ----
# 常用声源:
#   en-US-JennyNeural  (女声, 美式)
#   en-US-GuyNeural     (男声, 美式)
#   en-GB-SoniaNeural   (女声, 英式)
#   en-GB-RyanNeural    (男声, 英式)
#   en-AU-NatashaNeural (女声, 澳式)
TTS_VOICE=en-US-JennyNeural

# 模型: tiny（快速，低延迟）
WHISPER_MODEL_SIZE=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ---- Debug ----
DEBUG=true
